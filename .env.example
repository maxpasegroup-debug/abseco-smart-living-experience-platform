MONGODB_URI=
AUTH_SESSION_SECRET=

# Required for admin login. No fallback credentials are used.
ABSECO_ADMIN_EMAIL=
ABSECO_ADMIN_PASSWORD=
ABSECO_ADMIN_ROLE=admin
NEXT_PUBLIC_BASE_URL=

# Optional OTP provider marker. Production OTP requests fail if no provider is configured.
AUTH_OTP_PROVIDER=

# ABSECO WhatsApp Sales Engine (optional)
WHATSAPP_PROVIDER=meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
ABSECO_DEFAULT_BOOKING_MODE=fixed
ABSECO_DEFAULT_BOOKING_VALUE=0
ABSECO_DEFAULT_GST_PERCENTAGE=0

# Meta WhatsApp Cloud API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
# or: META_WHATSAPP_TOKEN=, META_WHATSAPP_PHONE_ID=

# Twilio
# TWILIO_ACCOUNT_SID=, TWILIO_AUTH_TOKEN=, TWILIO_WHATSAPP_FROM=

# Gupshup
# GUPSHUP_API_KEY=, GUPSHUP_APP_NAME=

# MSG91
# MSG91_AUTH_KEY=, MSG91_WHATSAPP_SENDER=
